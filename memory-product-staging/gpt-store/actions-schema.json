{
  "openapi": "3.1.0",
  "info": {
    "title": "0Latency Memory API",
    "description": "Persistent memory for AI agents. Store and recall structured memories across conversations.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://0latency.ai"
    }
  ],
  "paths": {
    "/memories/extract": {
      "post": {
        "operationId": "extractMemories",
        "summary": "Extract and store memories",
        "description": "Extracts structured memories from conversation turns. Returns immediately with 202 Accepted; processing happens asynchronously.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["agent_id", "messages"],
                "properties": {
                  "agent_id": {
                    "type": "string",
                    "description": "Unique identifier for the agent (e.g., 'user_default')",
                    "minLength": 1,
                    "maxLength": 128
                  },
                  "messages": {
                    "type": "array",
                    "description": "Conversation messages to extract memories from",
                    "items": {
                      "type": "object",
                      "required": ["role", "content"],
                      "properties": {
                        "role": {
                          "type": "string",
                          "enum": ["user", "assistant", "system"],
                          "description": "Message role"
                        },
                        "content": {
                          "type": "string",
                          "description": "Message content"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Accepted - extraction job queued",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "accepted"
                    },
                    "job_id": {
                      "type": "string",
                      "description": "Job ID for tracking extraction status"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/recall": {
      "post": {
        "operationId": "recallMemories",
        "summary": "Recall relevant memories",
        "description": "Retrieve relevant memories for a given conversation context using semantic search.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["agent_id", "messages"],
                "properties": {
                  "agent_id": {
                    "type": "string",
                    "description": "Unique identifier for the agent",
                    "minLength": 1,
                    "maxLength": 128
                  },
                  "messages": {
                    "type": "array",
                    "description": "Recent conversation context",
                    "items": {
                      "type": "object",
                      "required": ["role", "content"],
                      "properties": {
                        "role": {
                          "type": "string",
                          "enum": ["user", "assistant", "system"]
                        },
                        "content": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "limit": {
                    "type": "integer",
                    "description": "Maximum number of memories to return",
                    "default": 10,
                    "minimum": 1,
                    "maximum": 50
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully recalled memories",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "memories": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "description": "Memory ID"
                          },
                          "content": {
                            "type": "string",
                            "description": "Memory content"
                          },
                          "memory_type": {
                            "type": "string",
                            "description": "Type of memory (fact, preference, entity, etc.)"
                          },
                          "score": {
                            "type": "number",
                            "description": "Relevance score"
                          },
                          "created_at": {
                            "type": "string",
                            "format": "date-time"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/memories/search": {
      "get": {
        "operationId": "searchMemories",
        "summary": "Search memories by keyword",
        "description": "Search memories using keyword/text matching (not semantic).",
        "parameters": [
          {
            "name": "agent_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            "description": "Agent ID to search memories for"
          },
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500
            },
            "description": "Search query"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20,
              "minimum": 1,
              "maximum": 100
            },
            "description": "Maximum results to return"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "content": {
                        "type": "string"
                      },
                      "memory_type": {
                        "type": "string"
                      },
                      "created_at": {
                        "type": "string",
                        "format": "date-time"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/memories": {
      "get": {
        "operationId": "listMemories",
        "summary": "List all memories for an agent",
        "description": "Retrieve paginated list of all memories for a specific agent.",
        "parameters": [
          {
            "name": "agent_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            "description": "Agent ID"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50,
              "minimum": 1,
              "maximum": 200
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0,
              "minimum": 0
            }
          },
          {
            "name": "memory_type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "maxLength": 32
            },
            "description": "Filter by memory type"
          }
        ],
        "responses": {
          "200": {
            "description": "List of memories",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "content": {
                        "type": "string"
                      },
                      "memory_type": {
                        "type": "string"
                      },
                      "created_at": {
                        "type": "string",
                        "format": "date-time"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/memories/{memory_id}": {
      "delete": {
        "operationId": "deleteMemory",
        "summary": "Delete a specific memory",
        "description": "Permanently delete a memory by ID.",
        "parameters": [
          {
            "name": "memory_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Memory ID to delete"
          }
        ],
        "responses": {
          "200": {
            "description": "Memory deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "deleted"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/memories/export": {
      "get": {
        "operationId": "exportMemories",
        "summary": "Export all memories",
        "description": "Export all memories for an agent as JSON. For data portability and backup.",
        "parameters": [
          {
            "name": "agent_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            "description": "Agent ID to export memories for"
          }
        ],
        "responses": {
          "200": {
            "description": "Full memory export",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "agent_id": {
                      "type": "string"
                    },
                    "exported_at": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "memories": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "operationId": "healthCheck",
        "summary": "API health check",
        "description": "Check API availability and database connectivity. No authentication required.",
        "responses": {
          "200": {
            "description": "API is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "healthy"
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API key from 0latency.ai dashboard"
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ]
}

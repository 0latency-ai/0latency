# Zero Latency Memory API — Environment Variables
# Copy to .env and fill in your values

# ─── Database ────────────────────────────────────────────────────────────────
# REQUIRED — PostgreSQL connection string (Supabase pooler recommended)
MEMORY_DB_CONN=postgresql://user:password@host:5432/database

# ─── Supabase Auth ───────────────────────────────────────────────────────────
# REQUIRED — Supabase project URL and service role key (for auth.getUser verification)
MEMORY_SUPABASE_URL=https://your-project.supabase.co
MEMORY_SUPABASE_KEY=your-service-role-key

# ─── API Keys ────────────────────────────────────────────────────────────────
# REQUIRED — Admin key for tenant management endpoints
MEMORY_ADMIN_KEY=your_admin_secret_here

# REQUIRED — At least one embedding provider
GOOGLE_API_KEY=your_google_api_key
OPENAI_API_KEY=your_openai_api_key

# ─── Stripe Billing ─────────────────────────────────────────────────────────
# REQUIRED for billing — Stripe API keys
STRIPE_SECRET_KEY=sk_live_or_sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_live_or_pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# REQUIRED for billing — Stripe price IDs (get from Stripe Dashboard → Products)
STRIPE_PRO_PRODUCT_ID=prod_...
STRIPE_PRO_PRICE_ID_MONTHLY=price_...
STRIPE_PRO_PRICE_ID_YEARLY=price_...
STRIPE_SCALE_PRODUCT_ID=prod_...
STRIPE_SCALE_PRICE_ID_MONTHLY=price_...
STRIPE_SCALE_PRICE_ID_YEARLY=price_...

# ─── Redis ───────────────────────────────────────────────────────────────────
# OPTIONAL — Redis for rate limiting (falls back to in-memory if unavailable)
# Set to "disabled" to skip Redis entirely (e.g. local dev)
REDIS_URL=redis://127.0.0.1:6379/0

# ─── URLs ────────────────────────────────────────────────────────────────────
# REQUIRED — Base URLs for redirects (Stripe checkout, OAuth callbacks, etc.)
API_BASE_URL=https://api.0latency.ai
SITE_BASE_URL=https://0latency.ai

# ─── CORS ────────────────────────────────────────────────────────────────────
# OPTIONAL — Comma-separated allowed origins (default includes localhost:3000)
CORS_ORIGINS=https://0latency.ai,https://www.0latency.ai,https://api.0latency.ai,http://localhost:3000

# ─── Email (Resend) ─────────────────────────────────────────────────────────
# OPTIONAL — For transactional emails
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@0latency.ai
RESEND_SUPPORT_EMAIL=support@0latency.ai

# ─── Environment ─────────────────────────────────────────────────────────────
ENVIRONMENT=production

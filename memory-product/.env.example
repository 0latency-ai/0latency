# Zero Latency Memory API — Environment Variables
# Copy to .env or set in systemd service file

# REQUIRED — PostgreSQL connection string (Supabase pooler recommended)
MEMORY_DB_CONN=postgresql://user:password@host:5432/database

# REQUIRED — Admin key for tenant management endpoints
MEMORY_ADMIN_KEY=your_admin_secret_here

# REQUIRED — At least one embedding provider
GOOGLE_API_KEY=your_google_api_key        # Gemini embedding (preferred, cheaper)
OPENAI_API_KEY=your_openai_api_key        # OpenAI embedding (fallback)

# REQUIRED — LLM for memory extraction
GOOGLE_API_KEY=your_google_api_key        # Same key works for both

# OPTIONAL — CORS origins (comma-separated, default: https://your-server-ip)
CORS_ORIGINS=https://your-domain.com,https://164.90.156.169

# OPTIONAL — DB password for backup script (if using psql directly)
MEMORY_DB_PASSWORD=your_db_password

# CRITICAL FIX: Auth Rate Limiting
# Priority: P0 - Deploy before public launch
# Prevents brute-force attacks on /auth/email/login endpoint

## Problem
Currently, /auth/email/login has NO rate limiting. An attacker can attempt unlimited 
password guesses. Stress test confirmed: 50 failed login attempts with no 429 response.

## Solution
Add IP-based rate limiting: 10 attempts per 15 minutes per IP address.

## Files to Modify

### 1. api/auth_routes.py

Add rate limiting function and apply to login endpoint:

```python
# After imports, before router definition
from api.main import _get_redis
import time
import logging

logger = logging.getLogger("zerolatency")


def _check_auth_rate_limit(client_ip: str, max_attempts: int = 10, window_seconds: int = 900):
    """
    Rate limit auth attempts: 10 per 15 minutes per IP.
    Uses Redis for cross-worker consistency, falls back to blocking all on Redis failure.
    """
    r = _get_redis()
    if r:
        try:
            key = f"auth_rl:{client_ip}"
            count = r.incr(key)
            if count == 1:
                r.expire(key, window_seconds)
            if count > max_attempts:
                ttl = max(r.ttl(key), 1)
                logger.warning(f"auth_rate_limit_hit ip={client_ip} attempts={count}")
                raise HTTPException(
                    status_code=429,
                    detail={
                        "error": "too_many_attempts",
                        "message": f"Too many login attempts. Try again in {ttl} seconds.",
                        "retry_after": ttl,
                    },
                    headers={"Retry-After": str(ttl)}
                )
            return
        except HTTPException:
            raise
        except Exception as e:
            logger.error(f"Redis auth rate limit failed: {e}")
            # Fail closed: block all auth attempts if Redis is down
            raise HTTPException(
                status_code=503,
                detail="Authentication service temporarily unavailable. Please try again later."
            )
    else:
        # No Redis available - fail closed for security
        logger.warning(f"Redis unavailable for auth rate limiting - blocking request from {client_ip}")
        raise HTTPException(
            status_code=503,
            detail="Authentication service temporarily unavailable. Please try again later."
        )


# Modify login endpoint:
@router.post("/login", response_model=LoginResponse)
async def login(req: LoginRequest, request: Request, response: Response):
    """
    Login with email + password.
    Returns session token and API key.
    Rate limited: 10 attempts per 15 minutes per IP.
    """
    # Get client IP (handle proxies)
    client_ip = request.headers.get("x-forwarded-for", "").split(",")[0].strip()
    if not client_ip:
        client_ip = request.headers.get("x-real-ip", "")
    if not client_ip and request.client:
        client_ip = request.client.host
    if not client_ip:
        client_ip = "unknown"
    
    # Apply rate limiting BEFORE password verification
    _check_auth_rate_limit(client_ip)
    
    # Existing login logic
    user = auth.verify_password(req.email, req.password)
    
    if not user:
        # Log failed attempt for monitoring
        logger.warning(f"failed_login ip={client_ip} email={req.email}")
        raise HTTPException(401, detail="Invalid email or password")
    
    # ... rest of existing code
```


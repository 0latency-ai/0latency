{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "ai.0latency/memory",
  "description": "Persistent memory layer for AI agents. Automatically extracts, stores, and recalls memories across conversations with knowledge graph support.",
  "repository": {
    "url": "https://github.com/0latency-ai/mcp-server",
    "source": "github"
  },
  "version": "0.1.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@0latency/mcp-server",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Your 0Latency API key from https://0latency.ai",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "ZERO_LATENCY_API_KEY"
        },
        {
          "description": "API base URL (only needed for self-hosted deployments)",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "ZERO_LATENCY_API_URL"
        }
      ]
    }
  ]
}

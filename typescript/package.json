{
  "name": "zerolatency",
  "version": "1.0.0",
  "description": "TypeScript SDK for 0Latency - Add persistent memory to AI agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node16 --outfile=dist/index.js --external:@anthropic-ai/sdk --external:openai --external:@google/generative-ai",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "memory",
    "anthropic",
    "openai",
    "gemini",
    "claude",
    "gpt",
    "agents",
    "llm",
    "0latency"
  ],
  "author": "0Latency",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jghiglia2380/0Latency"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "openai": "^4.0.0",
    "@google/generative-ai": "^0.2.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@google/generative-ai": "^0.2.1",
    "@types/node": "^20.11.0",
    "esbuild": "^0.20.0",
    "openai": "^4.28.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  }
}

[Unit]
Description=0Latency Contribution Reviewer
After=network.target postgresql.service
Documentation=https://github.com/yourusername/0latency-contribution-reviewer

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/0latency-contribution-reviewer
Environment="PATH=/opt/0latency-contribution-reviewer/venv/bin"
EnvironmentFile=/opt/0latency-contribution-reviewer/.env
ExecStart=/opt/0latency-contribution-reviewer/venv/bin/python main.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/0latency-contribution-reviewer

[Install]
WantedBy=multi-user.target
